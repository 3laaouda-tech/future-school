PORT=5000

# Local development: fill in these variables
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=school_management

# Cloud deployment (Neon, Supabase, etc.): set this instead, and the
# variables above will be ignored. Get this from your provider's dashboard.
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

JWT_SECRET=change_this_to_a_long_random_string
